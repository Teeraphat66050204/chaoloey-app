<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Time Selection -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- Hours -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/hourUp"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Hour Up"
                android:src="@drawable/ic_up"
                app:tint="@color/login_text_primary"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/hourPickerEdit"
                android:layout_width="60dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:inputType="number"
                android:text="10"
                android:textAlignment="center"
                android:textColor="@color/login_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:focusable="false" />

            <ImageView
                android:id="@+id/hourDown"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Hour Down"
                android:src="@drawable/ic_down"
                app:tint="@color/login_text_primary"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Colon separator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="@color/login_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="8dp" />

        <!-- Minutes -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/minuteUp"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Minute Up"
                android:src="@drawable/ic_up"
                app:tint="@color/login_text_primary"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/minutePickerEdit"
                android:layout_width="60dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:inputType="number"
                android:text="30"
                android:textAlignment="center"
                android:textColor="@color/login_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:focusable="false" />

            <ImageView
                android:id="@+id/minuteDown"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Minute Down"
                android:src="@drawable/ic_down"
                app:tint="@color/login_text_primary"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- AM/PM Toggle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/amButton"
                android:layout_width="48dp"
                android:layout_height="40dp"
                android:background="@drawable/button_ampm_selector"
                android:text="am"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/pmButton"
                android:layout_width="48dp"
                android:layout_height="40dp"
                android:background="@drawable/button_ampm_selector"
                android:text="pm"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Location indicator -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_location"
                android:contentDescription="Location"
                app:tint="@color/login_text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Calendar -->
    <CalendarView
        android:id="@+id/calendarView"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginBottom="24dp"
        android:dateTextAppearance="@style/CalendarDateTextAppearance"
        android:weekDayTextAppearance="@style/CalendarWeekDayTextAppearance" />

    <!-- Blocked date warning -->
    <TextView
        android:id="@+id/tvBlockedWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ วันที่เลือกถูกจองแล้ว กรุณาเลือกวันอื่น"
        android:textColor="@color/color_error"
        android:textSize="13sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/button_secondary_background"
            android:text="Cancel"
            android:textColor="@color/login_button_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/doneButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/login_button_primary_background"
            android:text="Done"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>



